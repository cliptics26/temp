FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

# System deps
RUN apt-get update -qq && \
    apt-get install -y -qq ffmpeg git-lfs wget curl && \
    git lfs install && \
    rm -rf /var/lib/apt/lists/*

# Core ML deps — exact versions that work together
RUN pip install --no-cache-dir \
    torch==2.4.1 torchvision==0.19.1 torchaudio==2.4.1 \
    --index-url https://download.pytorch.org/whl/cu121

RUN pip install --no-cache-dir \
    xformers==0.0.28 \
    --index-url https://download.pytorch.org/whl/cu121

RUN pip install --no-cache-dir \
    flash_attn==2.7.4.post1 \
    ninja psutil packaging

# Pinned versions — these MUST match exactly
RUN pip install --no-cache-dir \
    "diffusers==0.35.0" \
    "transformers==4.49.0" \
    "numpy>=1.23.5,<2" \
    "optimum-quanto==0.2.6" \
    "huggingface_hub[cli]" \
    "accelerate>=1.1.1" \
    librosa peft xfuser \
    opencv-python-headless imageio imageio-ffmpeg \
    easydict ftfy scikit-image loguru pyloudnorm \
    tokenizers

# Fix: huggingface-cli entry point not created on this image
RUN printf '#!/usr/bin/env python3\nimport sys\nfrom huggingface_hub.cli.hf import main\nsys.exit(main())\n' \
    > /usr/local/bin/huggingface-cli && \
    chmod +x /usr/local/bin/huggingface-cli

# FastAPI server for HTTP API
RUN pip install --no-cache-dir fastapi uvicorn

# Clone model repos to /opt/models (not /workspace, which gets overlaid by volume)
RUN mkdir -p /opt/models
RUN git clone --depth 1 https://github.com/MeiGen-AI/MultiTalk.git /opt/models/MultiTalk && \
    git clone --depth 1 https://github.com/MeiGen-AI/InfiniteTalk.git /opt/models/InfiniteTalk && \
    git clone --depth 1 https://github.com/Omni-Avatar/OmniAvatar.git /opt/models/OmniAvatar

# Install repo-specific requirements (may overlap, that's fine)
RUN cd /opt/models/MultiTalk && pip install --no-cache-dir -r requirements.txt 2>/dev/null || true
RUN cd /opt/models/InfiniteTalk && pip install --no-cache-dir -r requirements.txt 2>/dev/null || true
RUN cd /opt/models/OmniAvatar && pip install --no-cache-dir -r requirements.txt 2>/dev/null || true

# Re-pin versions that requirements.txt may have overwritten
RUN pip install --no-cache-dir \
    "diffusers==0.35.0" \
    "transformers==4.49.0" \
    "numpy>=1.23.5,<2" \
    "flash_attn==2.7.4.post1" \
    xfuser peft

# Patch 1: ArgSpec removed in Python 3.11
RUN sed -i 's/from inspect import ArgSpec/from inspect import FullArgSpec as ArgSpec/' \
    /opt/models/MultiTalk/wan/multitalk.py

# Patch 2: Make Kokoro TTS import optional (we provide our own audio)
RUN cd /opt/models/MultiTalk && python3 -c "\
import pathlib; \
p = pathlib.Path('generate_multitalk.py'); \
t = p.read_text(); \
t = t.replace('from kokoro import KPipeline', 'try:\n    from kokoro import KPipeline\nexcept ImportError:\n    KPipeline = None'); \
p.write_text(t); \
print('Patched Kokoro import')"

# Copy server script to /app (not /workspace, which gets overlaid by volume mount)
COPY pod-server.py /app/pod-server.py

# Create output dirs (will be recreated on volume at runtime)
RUN mkdir -p /workspace/test /workspace/outputs /workspace/weights

EXPOSE 8000

# Entrypoint: copy model code to volume if needed, then start server
# Volume mount at /workspace overlays Docker image's /workspace,
# so we copy model repos from image to volume on first boot
CMD ["bash", "-c", "\
  mkdir -p /workspace/test /workspace/outputs /workspace/weights && \
  [ ! -d /workspace/MultiTalk ] && cp -r /opt/models/MultiTalk /workspace/MultiTalk || true && \
  [ ! -d /workspace/InfiniteTalk ] && cp -r /opt/models/InfiniteTalk /workspace/InfiniteTalk || true && \
  [ ! -d /workspace/OmniAvatar ] && cp -r /opt/models/OmniAvatar /workspace/OmniAvatar || true && \
  cp /app/pod-server.py /workspace/pod-server.py && \
  python3 -u /app/pod-server.py"]
